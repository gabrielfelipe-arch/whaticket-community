# WhatsApp Provider Configuration
# Supported providers: wwebjs, whaileys
WHATSAPP_PROVIDER=wwebjs

# Logging (silent, fatal, error, warn, info, debug, trace)
LOG_LEVEL=info
WHAILEYS_LOG_LEVEL=error

# Chrome/Puppeteer Configuration
CHROME_BIN=
CHROME_WS=
CHROME_ARGS=--no-sandbox --disable-setuid-sandbox

# Database
# Supported dialects: mysql, mariadb, postgres
DB_HOST=localhost
DB_DIALECT=postgres
DB_PORT=5432
DB_NAME=whaticket_pg
DB_USER=whaticket
DB_PASS=troque-por-uma-senha-forte

# JWT Secrets
JWT_SECRET=gere-um-token-forte
JWT_REFRESH_SECRET=gere-outro-token-forte

# Backend URL publico. Se o backend ficar atras do Nginx do frontend, use o mesmo endereco do FRONTEND_URL.
BACKEND_URL=http://localhost:3000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Proxy
PROXY_PORT=80

# Redis
IO_REDIS_SERVER=127.0.0.1
IO_REDIS_PASSWORD=
IO_REDIS_PORT=6379
IO_REDIS_DB_SESSION=2
